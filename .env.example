# Supabase Database Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_publishable_key
SUPABASE_SECRET_KEY=your_supabase_secret_key_server_only

# Resend Email Service Configuration (server-only; never use NEXT_PUBLIC_)
RESEND_API_KEY=your_resend_api_key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel Configuration (Optional for local development, required for CI/CD)
VERCEL_TOKEN=your_vercel_personal_access_token
